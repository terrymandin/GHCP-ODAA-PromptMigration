# ============================================================
# ZDM Response File Template
# Migration: POCAKV -> POCAKV_ODAA
# Generated: 2026-03-17
# ============================================================
# IMPORTANT:
# 1) This file uses environment variable placeholders for OCI identifiers.
# 2) Render a runtime file before execution, for example:
#      envsubst < zdm_migrate_POCAKV.rsp > zdm_migrate_POCAKV.runtime.rsp
# 3) Ensure password files in ~/creds exist before running zdmcli.

# Migration method
MIGRATION_METHOD=ONLINE_PHYSICAL

# Source database
SOURCEDATABASE_DBUNIQUEID=POCAKV
SOURCEDATABASE_CONNECTIONDETAILS_HOST=10.200.1.12
SOURCEDATABASE_CONNECTIONDETAILS_PORT=1521
SOURCEDATABASE_CONNECTIONDETAILS_SERVICENAME=POCAKV
SOURCEDATABASE_CONNECTIONDETAILS_SID=POCAKV
SOURCEDATABASE_CONNECTIONDETAILS_DBHOME=/u01/app/oracle/product/19.0.0/dbhome_1
SOURCEDATABASE_ADMINUSERNAME=sys
SOURCEDATABASE_ADMINPASSWORD_FILE=${HOME}/creds/source_sys_password.txt

# Target database
TARGETDATABASE_DBUNIQUEID=POCAKV_ODAA
TARGETDATABASE_CONNECTIONDETAILS_HOST=10.200.0.250
TARGETDATABASE_CONNECTIONDETAILS_PORT=1521
TARGETDATABASE_CONNECTIONDETAILS_SERVICENAME=POCAKV_ODAA
TARGETDATABASE_CONNECTIONDETAILS_SID=POCAKV1
TARGETDATABASE_CONNECTIONDETAILS_DBHOME=/u02/app/oracle/product/19.0.0.0/dbhome_1
TARGETDATABASE_ADMINUSERNAME=sys
TARGETDATABASE_ADMINPASSWORD_FILE=${HOME}/creds/target_sys_password.txt
TARGETDATABASE_OCID=${TARGET_DATABASE_OCID}

# OCI authentication for target
OCIAUTHENTICATION_METHOD=API_KEY
OCIAUTHENTICATION_USERPRINCIPAL_TENANTID=${TARGET_TENANCY_OCID}
OCIAUTHENTICATION_USERPRINCIPAL_USERID=${TARGET_USER_OCID}
OCIAUTHENTICATION_USERPRINCIPAL_FINGERPRINT=${TARGET_FINGERPRINT}
OCIAUTHENTICATION_USERPRINCIPAL_PRIVATEKEYFILE=${HOME}/.oci/oci_api_key.pem
OCI_TARGET_COMPARTMENT_OCID=${TARGET_COMPARTMENT_OCID}

# Optional object storage namespace
# Required for OFFLINE_PHYSICAL patterns; optional for ONLINE_PHYSICAL to Oracle Database@Azure.
OBJECTSTORAGE_NAMESPACE=${TARGET_OBJECT_STORAGE_NAMESPACE}

# Network and transport defaults
DATATRANSFER_MEDIUM=OSS
TDE_WALLET_PASSWORD_FILE=${HOME}/creds/tde_password.txt

# Data Guard and online migration behavior
DATAGUARDCONFIGURATION=MAXPERFORMANCE
SKIP_FALLBACK=false

# Logging and diagnostics
JOBTAG=Step5-POCAKV-to-POCAKV_ODAA
