# ===========================================
# ZDM Response File
# Migration Type: ONLINE_PHYSICAL (default)
# Generated: 2026-03-18
# ===========================================
#
# IMPORTANT
# - This file intentionally uses environment variable placeholders like ${TARGET_TENANCY_OCID}.
# - Generate a runtime file with substitution before use:
#     envsubst < zdm_migrate.rsp > /tmp/zdm_migrate.generated.rsp
# - OCI CLI is optional and not required.
#

# Migration Method
MIGRATION_METHOD=ONLINE_PHYSICAL

# Source Database Configuration
SOURCEDATABASE_CONNECTIONDETAILS_HOST=10.200.1.12
SOURCEDATABASE_CONNECTIONDETAILS_PORT=1521
SOURCEDATABASE_CONNECTIONDETAILS_SERVICENAME=POCAKV
SOURCEDATABASE_CONNECTIONDETAILS_DBUNIQUE=POCAKV
SOURCEDATABASE_CONNECTIONDETAILS_SID=POCAKV
SOURCEDATABASE_ORACLEHOME=/u01/app/oracle/product/19.0.0/dbhome_1
SOURCEDATABASE_ADMINUSERNAME=SYS
SOURCEDATABASE_ADMINPASSWORDFILE=${HOME}/creds/src_sys_password.txt

# Target Database Configuration
TARGETDATABASE_CONNECTIONDETAILS_HOST=10.200.0.250
TARGETDATABASE_CONNECTIONDETAILS_PORT=1521
TARGETDATABASE_CONNECTIONDETAILS_SERVICENAME=POCAKV_ODAA
TARGETDATABASE_CONNECTIONDETAILS_DBUNIQUE=POCAKV_ODAA
TARGETDATABASE_CONNECTIONDETAILS_SID=POCAKV1
TARGETDATABASE_ORACLEHOME=/u02/app/oracle/product/19.0.0.0/dbhome_1
TARGETDATABASE_ADMINUSERNAME=SYS
TARGETDATABASE_ADMINPASSWORDFILE=${HOME}/creds/tgt_sys_password.txt
TARGETDATABASE_TDEWALLETPASSWORDFILE=${HOME}/creds/tde_wallet_password.txt
TARGETDATABASE_OCID=${TARGET_DATABASE_OCID}

# OCI Authentication
OCIAUTHENTICATION_TYPE=API_KEY
OCIAUTHENTICATION_USERPRINCIPAL_TENANTID=${TARGET_TENANCY_OCID}
OCIAUTHENTICATION_USERPRINCIPAL_USERID=${TARGET_USER_OCID}
OCIAUTHENTICATION_USERPRINCIPAL_FINGERPRINT=${TARGET_FINGERPRINT}
OCIAUTHENTICATION_USERPRINCIPAL_PRIVATEKEYFILE=${OCI_API_PRIVATE_KEY_FILE}

# Compartment Configuration
OCI_COMPARTMENT_OCID=${TARGET_COMPARTMENT_OCID}

# Optional Object Storage (required for OFFLINE_PHYSICAL or staging patterns)
OBJECTSTORAGE_NAMESPACE=${TARGET_OBJECT_STORAGE_NAMESPACE}

# Optional Source OCI (if source environment is OCI)
SOURCE_OCI_TENANCY_OCID=${SOURCE_TENANCY_OCID}
SOURCE_OCI_COMPARTMENT_OCID=${SOURCE_COMPARTMENT_OCID}
SOURCE_DATABASE_OCID=${SOURCE_DATABASE_OCID}

# Data Guard / Online Physical Defaults
DATAGUARD_CONFIGURE=TRUE
DATAGUARD_PROTECTION_MODE=MAXPERFORMANCE
DATAGUARD_TRANSPORT_MODE=ASYNC
DATAGUARD_FAST_START_FAILOVER=FALSE

# General Controls
TDE_CONFIGURATION=TRUE
SKIP_FALLBACK=FALSE
SKIP_PRECHECKS=FALSE

# SSH and host access (defaults use agent/default auth)
SSH_USER_SOURCE=azureuser
SSH_USER_TARGET=opc
SSH_KEY_SOURCE=
SSH_KEY_TARGET=

# Placeholders for project-specific policy values
TARGET_CONTAINER_DATABASE_NAME=[TBD if CDB-specific parameter required in your release]
MIGRATION_TAG=[TBD-ChangeTicketOrReleaseTag]
