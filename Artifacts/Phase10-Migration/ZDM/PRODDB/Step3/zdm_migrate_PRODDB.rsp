# ===========================================
# ZDM Response File
# Database: PRODDB
# Migration Type: ONLINE_PHYSICAL (Data Guard)
# Generated: 2026-02-04
# ===========================================
#
# IMPORTANT: This file contains environment variable placeholders (${VAR_NAME})
# that MUST be substituted before use.
#
# Option 1: Use envsubst
#   export TARGET_DATABASE_OCID="ocid1.database..."
#   envsubst < zdm_migrate_PRODDB.rsp > zdm_migrate_PRODDB_ready.rsp
#
# Option 2: Manual substitution
#   Replace all ${VAR_NAME} with actual values
#
# Required environment variables:
#   TARGET_DATABASE_OCID     - Target database OCID
#   TARGET_TENANCY_OCID      - OCI tenancy OCID
#   TARGET_USER_OCID         - OCI user OCID
#   TARGET_FINGERPRINT       - OCI API key fingerprint
#   TARGET_COMPARTMENT_OCID  - Target compartment OCID
#
# Optional environment variables (for OFFLINE_PHYSICAL only):
#   TARGET_OBJECT_STORAGE_NAMESPACE - Object Storage namespace
#
# ===========================================

# -------------------------------------------
# Migration Method
# -------------------------------------------
# ONLINE_PHYSICAL uses Data Guard for minimal downtime
MIGRATION_METHOD=ONLINE_PHYSICAL

# -------------------------------------------
# Source Database Configuration
# -------------------------------------------
SOURCEDATABASE_CONNECTIONDETAILS_HOST=proddb01.corp.example.com
SOURCEDATABASE_CONNECTIONDETAILS_PORT=1521
SOURCEDATABASE_CONNECTIONDETAILS_SERVICENAME=PRODDB.corp.example.com
SOURCEDATABASE_ADMINUSERNAME=SYS
SOURCEDATABASE_ADMINPASSWORDFILE=/home/zdmuser/creds/source_sys_password.txt
SOURCEDATABASE_ORACLEHOME=/u01/app/oracle/product/19.21.0/dbhome_1
SOURCEDATABASE_UNIQUENAME=PRODDB_PRIMARY

# Source SSH Configuration
SOURCEDATABASE_SSHUSER=oracle
SOURCEDATABASE_SSHKEYFILE=/home/zdmuser/.ssh/zdm_migration_key
SOURCEDATABASE_SUDOLOCATION=/usr/bin/sudo

# -------------------------------------------
# Target Database Configuration
# -------------------------------------------
# NOTE: Environment variable substitution required
TARGETDATABASE_OCID=${TARGET_DATABASE_OCID}
TARGETDATABASE_CONNECTIONDETAILS_HOST=proddb-oda.eastus.azure.example.com
TARGETDATABASE_CONNECTIONDETAILS_PORT=1521
TARGETDATABASE_CONNECTIONDETAILS_SERVICENAME=PRODDB_AZURE.eastus.azure.example.com
TARGETDATABASE_ADMINUSERNAME=SYS
TARGETDATABASE_ADMINPASSWORDFILE=/home/zdmuser/creds/target_sys_password.txt
TARGETDATABASE_ORACLEHOME=/u02/app/oracle/product/19.0.0.0/dbhome_1
TARGETDATABASE_UNIQUENAME=PRODDB_AZURE

# Target SSH Configuration
TARGETDATABASE_SSHUSER=oracle
TARGETDATABASE_SSHKEYFILE=/home/zdmuser/.ssh/zdm_migration_key
TARGETDATABASE_SUDOLOCATION=/usr/bin/sudo

# -------------------------------------------
# OCI Authentication
# -------------------------------------------
# NOTE: Environment variable substitution required
OCIAUTHENTICATION_TYPE=API_KEY
OCIAUTHENTICATION_USERPRINCIPAL_TENANTID=${TARGET_TENANCY_OCID}
OCIAUTHENTICATION_USERPRINCIPAL_USERID=${TARGET_USER_OCID}
OCIAUTHENTICATION_USERPRINCIPAL_FINGERPRINT=${TARGET_FINGERPRINT}
OCIAUTHENTICATION_USERPRINCIPAL_PRIVATEKEYFILE=/home/zdmuser/.oci/oci_api_key.pem

# -------------------------------------------
# Compartment Configuration
# -------------------------------------------
# NOTE: Environment variable substitution required
OCI_COMPARTMENT_OCID=${TARGET_COMPARTMENT_OCID}

# -------------------------------------------
# Object Storage Configuration (OPTIONAL)
# -------------------------------------------
# NOTE: Object Storage is NOT required for ONLINE_PHYSICAL migrations
#       to Oracle Database@Azure. ZDM uses direct Data Guard redo shipping.
#       Uncomment only if you need backup staging for OFFLINE_PHYSICAL.
#
# OBJECTSTORAGE_NAMESPACE=${TARGET_OBJECT_STORAGE_NAMESPACE}
# OBJECTSTORAGE_BUCKETNAME=zdm-proddb-migration
# OBJECTSTORAGE_REGION=us-ashburn-1

# -------------------------------------------
# TDE Configuration
# -------------------------------------------
# TDE is ENABLED on source database
TDE_ENABLED=TRUE
TDE_WALLET_LOCATION=/u01/app/oracle/admin/PRODDB/wallet/tde
TDE_WALLET_PASSWORDFILE=/home/zdmuser/creds/tde_password.txt

# -------------------------------------------
# Data Guard Configuration (Online Migration)
# -------------------------------------------
DATAGUARD_PROTECTIONMODE=MAXIMUM_PERFORMANCE
DATAGUARD_TRANSPORTTYPE=ASYNC

# Data Guard Redo Transport Configuration
# FASTSYNC - Uses ASYNC but can switch to SYNC for final apply
# ASYNC - Asynchronous redo shipping (recommended for WAN)
DATAGUARD_REDOTRANSPORTMODE=ASYNC

# Apply Mode
# APPLY - Real-time apply
# NONAPPLY - Delayed apply (not recommended for migration)
DATAGUARD_APPLYMODE=APPLY

# -------------------------------------------
# RMAN Configuration
# -------------------------------------------
RMAN_CHANNELS=8
RMAN_COMPRESSION=MEDIUM
RMAN_ENCRYPTION=AES256

# Parallelism settings
RMAN_PARALLELISM=8

# -------------------------------------------
# Migration Control Options
# -------------------------------------------
# Pause before switchover for final validation
PAUSEAFTER=ZDM_CONFIGURE_DG_SRC

# Auto switchover setting
# NO - Manual control, requires resume command
# YES - Automatic switchover (not recommended for production)
AUTO_SWITCHOVER=NO

# -------------------------------------------
# Post-Migration Options
# -------------------------------------------
# Keep backups for rollback capability
DELETE_BACKUP_AFTER_MIGRATION=FALSE

# Include performance data (AWR/baseline)
INCLUDE_PERFORMANCE_DATA=TRUE

# Evaluate Datapump feasibility
EVALUATE_DATAPUMP=TRUE

# -------------------------------------------
# Network Configuration
# -------------------------------------------
# Source network ports
SOURCE_LISTENER_PORT=1521
SOURCE_SSH_PORT=22

# Target network ports
TARGET_LISTENER_PORT=1521
TARGET_SSH_PORT=22

# -------------------------------------------
# Logging and Diagnostics
# -------------------------------------------
# Enable verbose logging for troubleshooting
VERBOSE_LOGGING=TRUE

# Keep job files after completion
KEEP_JOB_FILES=TRUE

# -------------------------------------------
# Database Character Set (Verified Match)
# -------------------------------------------
# Source: AL32UTF8
# Target: AL32UTF8
# Character set conversion: NOT REQUIRED

# -------------------------------------------
# Database Link Handling
# -------------------------------------------
# Note: Database link SYS_HUB will need manual recreation post-migration
# See runbook for details

# ===========================================
# END OF RSP FILE
# ===========================================
