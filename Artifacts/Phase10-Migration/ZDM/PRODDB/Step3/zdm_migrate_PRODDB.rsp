# ===========================================
# ZDM Response File
# Database: PRODDB
# Migration Type: ONLINE_PHYSICAL (Data Guard)
# Generated: 2026-02-04
# ===========================================
#
# IMPORTANT: This RSP file contains environment variable placeholders
# (e.g., ${TARGET_TENANCY_OCID}) that must be substituted before use.
#
# Option 1: Use envsubst (recommended)
#   source ~/zdm_oci_env.sh
#   envsubst < zdm_migrate_PRODDB.rsp > zdm_migrate_PRODDB_resolved.rsp
#
# Option 2: Manual substitution
#   Replace all ${VAR_NAME} with actual values
#
# ===========================================

# -------------------------------------------
# MIGRATION METHOD
# -------------------------------------------
# ONLINE_PHYSICAL - Uses Data Guard for minimal downtime migration
# OFFLINE_PHYSICAL - Uses RMAN backup/restore
MIGRATION_METHOD=ONLINE_PHYSICAL

# -------------------------------------------
# SOURCE DATABASE CONFIGURATION
# -------------------------------------------
SOURCEDATABASE_CONNECTIONDETAILS_HOST=proddb01.corp.example.com
SOURCEDATABASE_CONNECTIONDETAILS_PORT=1521
SOURCEDATABASE_CONNECTIONDETAILS_SERVICENAME=PRODDB.corp.example.com
SOURCEDATABASE_DBNAME=PRODDB
SOURCEDATABASE_DBUNIQUENAME=PRODDB_PRIMARY
SOURCEDATABASE_ORACLEHOME=/u01/app/oracle/product/19.21.0/dbhome_1

# Source database SYS password file
# Created at runtime from SOURCE_SYS_PASSWORD environment variable
SOURCEDATABASE_ADMINPASSWORDFILE=/home/zdmuser/creds/source_sys_password.txt

# Source SSH configuration
SOURCEDATABASE_SSHUSER=oracle
SOURCEDATABASE_SSHKEYFILE=/home/zdmuser/.ssh/zdm_migration_key

# -------------------------------------------
# TARGET DATABASE CONFIGURATION
# -------------------------------------------
# NOTE: TARGET_DATABASE_OCID must be set in environment before using this file
TARGETDATABASE_OCID=${TARGET_DATABASE_OCID}
TARGETDATABASE_CONNECTIONDETAILS_HOST=proddb-oda.eastus.azure.example.com
TARGETDATABASE_CONNECTIONDETAILS_PORT=1521
TARGETDATABASE_CONNECTIONDETAILS_SERVICENAME=PRODDB_AZURE.eastus.azure.example.com
TARGETDATABASE_DBNAME=PRODDB
TARGETDATABASE_DBUNIQUENAME=PRODDB_AZURE
TARGETDATABASE_ORACLEHOME=/u02/app/oracle/product/19.0.0.0/dbhome_1

# Target database SYS password file
# Created at runtime from TARGET_SYS_PASSWORD environment variable
TARGETDATABASE_ADMINPASSWORDFILE=/home/zdmuser/creds/target_sys_password.txt

# Target SSH configuration
TARGETDATABASE_SSHUSER=oracle
TARGETDATABASE_SSHKEYFILE=/home/zdmuser/.ssh/zdm_migration_key

# -------------------------------------------
# OCI AUTHENTICATION
# -------------------------------------------
# These values must be set via environment variables before migration
# See ~/zdm_oci_env.sh for configuration
OCIAUTHENTICATION_TYPE=API_KEY
OCIAUTHENTICATION_USERPRINCIPAL_TENANTID=${TARGET_TENANCY_OCID}
OCIAUTHENTICATION_USERPRINCIPAL_USERID=${TARGET_USER_OCID}
OCIAUTHENTICATION_USERPRINCIPAL_FINGERPRINT=${TARGET_FINGERPRINT}
OCIAUTHENTICATION_USERPRINCIPAL_PRIVATEKEYFILE=/home/zdmuser/.oci/oci_api_key.pem

# -------------------------------------------
# COMPARTMENT CONFIGURATION
# -------------------------------------------
OCI_COMPARTMENT_OCID=${TARGET_COMPARTMENT_OCID}

# -------------------------------------------
# OBJECT STORAGE CONFIGURATION (OPTIONAL)
# -------------------------------------------
# NOTE: For ONLINE_PHYSICAL migrations to Oracle Database@Azure,
# Object Storage is NOT required. ZDM uses direct Data Guard redo shipping.
# Only configure these if you specifically need backup staging.
#
# OBJECTSTORAGE_NAMESPACE=${TARGET_OBJECT_STORAGE_NAMESPACE}
# OBJECTSTORAGE_BUCKETNAME=zdm-proddb-migration
# OBJECTSTORAGE_REGION=us-ashburn-1
# OBJECTSTORAGE_CREATEBUCKET=TRUE

# -------------------------------------------
# DATA GUARD CONFIGURATION (ONLINE_PHYSICAL)
# -------------------------------------------
# Protection Mode: MAXIMUM_PERFORMANCE (async), MAXIMUM_AVAILABILITY (sync)
DATAGUARDDCONFIG_PROTECTIONMODE=MAXIMUM_PERFORMANCE

# Transport Type: ASYNC (asynchronous), SYNC (synchronous)
DATAGUARDDCONFIG_TRANSPORTTYPE=ASYNC

# Redo log transport settings
DATAGUARDDCONFIG_REDOAPPLY=TRUE

# -------------------------------------------
# RMAN CONFIGURATION
# -------------------------------------------
# Number of RMAN channels for backup/restore
RMAN_CHANNELS=8

# Compression level: BASIC, LOW, MEDIUM, HIGH
RMAN_COMPRESSION=MEDIUM

# Encryption algorithm for backups
RMAN_ENCRYPTION=AES256

# -------------------------------------------
# TDE CONFIGURATION
# -------------------------------------------
# TDE is enabled on source database
TDE_ENABLED=TRUE
TDE_WALLET_LOCATION=/u01/app/oracle/admin/PRODDB/wallet/tde

# TDE wallet password file
# Created at runtime from SOURCE_TDE_WALLET_PASSWORD environment variable
TDE_WALLET_PASSWORD_FILE=/home/zdmuser/creds/tde_password.txt

# -------------------------------------------
# PAUSE CONFIGURATION
# -------------------------------------------
# Migration will pause at this phase for validation before switchover
# This allows manual verification of Data Guard sync status
PAUSEAFTER=ZDM_CONFIGURE_DG_SRC

# -------------------------------------------
# SWITCHOVER CONFIGURATION
# -------------------------------------------
# Auto switchover: If TRUE, switchover happens automatically
# Recommended: FALSE for manual validation before switchover
SWITCHOVER_AUTO=FALSE

# -------------------------------------------
# POST-MIGRATION OPTIONS
# -------------------------------------------
# Keep backup after migration (for rollback capability)
DELETE_BACKUP_AFTER_MIGRATION=FALSE

# Include performance/AWR data
INCLUDE_PERFORMANCE_DATA=TRUE

# Evaluate DataPump feasibility
EVALUATE_DATAPUMP=TRUE

# -------------------------------------------
# ADDITIONAL OPTIONS
# -------------------------------------------
# Skip application tablespace validation (if needed)
# SKIP_TABLESPACE_CHECK=FALSE

# Force migration even with warnings
# IGNORE_PRECHECK_WARNING=FALSE
